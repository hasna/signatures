{
  "name": "@hasna/signatures",
  "version": "0.1.3",
  "description": "Open source e-signature platform \u2014 sign PDFs locally, manage documents, MCP + CLI + API",
  "type": "module",
  "bin": {
    "open-signatures": "dist/cli/index.js",
    "signatures-mcp": "dist/mcp/index.js",
    "signatures-serve": "dist/server/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/cli/index.tsx --outdir dist/cli --target bun --external ink --external react --external @hasna/attachments && bun build src/mcp/index.ts --outdir dist/mcp --target bun --external @hasna/attachments && bun build src/server/index.ts --outdir dist/server --target bun --external @hasna/attachments && bun build src/index.ts --outdir dist --target bun --external @hasna/attachments",
    "dev:serve": "bun run src/server/index.ts",
    "dev:mcp": "bun run src/mcp/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "postinstall": "mkdir -p $HOME/.hasna/signatures/{documents,signed,signatures,cache} 2>/dev/null || true"
  },
  "dependencies": {
    "@hasna/attachments": "latest",
    "@hasna/cloud": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ink": "^5.0.0",
    "nanoid": "^5.0.7",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "signatures",
    "esignature",
    "pdf",
    "mcp",
    "cli",
    "open-source"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/open-signatures"
  }
}